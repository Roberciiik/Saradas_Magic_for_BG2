@103 = ~To TY? Znowu? Œledzisz mnie?~
@104 = ~To doœæ ³atwe do przewidzenia, zwa¿ywszy na to, kim jesteœ. Ale bez obaw, wszystkie odpowiedzi poznasz we w³aœciwym czasie. Nikt nie mo¿e wp³yn¹æ na twoje przeznaczenia ani mu przeszkodziæ. Doœæ powiedzieæ, ¿e jesteœ jedynym architektem swojego ¿ycia, <CHARNAME>. Ale doœæ ju¿ tych powa¿nych tematów. Co mogê dla ciebie zrobiæ?~ 
@105 = ~Dlaczego wszysy czarodzieje musz¹ byæ tak tajemniczy? No dobrze, poka¿ mi na razie swoje towary.~
@106 = ~Na razie nic. Lepiej zabiorê siê za poszukiwanie Imoen...~
@107 = ~Zgadzam siê. Coœ mi mówi, ¿e twoja przyjació³ka s³u¿y tylko za przynêtê, by schwytaæ ciebie. Z pewnoœci¹ nied³ugo czagoœ siê o niej dowiesz.~ 
@108 = ~To nie pomy³ka. Wiem dobrze, kim jesteœ. Obserwowa³em twoje postêpy od momentu twojego pierwszego pojawienia siê w gospodzie Pod Pomocn¹ D³oni¹. Pozwól, ¿e siê przedstawiê. Nazywam siê Saradas, jestem podró¿nikiem i nauczycielem sztuk magicznych. Przez ca³e ¿ycie podró¿owa³em po Faerunie w poszukiwaniu wiedzy i zaginionych artefaktów. Jak widzisz, mój wiek nie pozwala mi d³u¿ej cieszyæ siê takimi wêdrówkami. Teraz wiêc zajmujê siê udzielaniem rad i pomocy m³odym poszukiwaczom przygód, jeœli s¹ w potrzebie. Mam te¿ na sprzeda¿ trochê zaklêæ, które sam stworzy³em. Jeœli ciê to interesuje, mo¿esz obejrzeæ moje towary.~
@109 = ~Rozumiem. Poka¿, co masz do zaoferowania, magu.~ 
@110 = ~Nie jestem zainteresowany. Chcia³bym raczej zapytaæ ciê o moj¹ przyjació³kê. Zosta³a porwana przez jakichœ szalonych magów znanych jako Zakapturzeni Czarodzieje. Wiesz coœ o nich?~ ~Nie jestem zainteresowana. Chcia³abym raczej zapytaæ ciê o moj¹ przyjació³kê. Zosta³a porwana przez jakichœ szalonych magów znanych jako Zakapturzeni Czarodzieje. Wiesz coœ o nich?~
@178 = ~Och, ju¿ ich spotka³eœ. Byli niegdyœ tajn¹ organizacj¹ utworzon¹, by strzec wiedzy i porz¹dku. Obecnie s¹ zdeprawowani i nadu¿ywaj¹ swojej pozycji, by ograniczaæ u¿ywanie magii. Lepiej z nimi nie zadzieraj.~ ~Och, ju¿ ich spotka³aœ. Byli niegdyœ tajn¹ organizacj¹ utworzon¹, by strzec wiedzy i porz¹dku. Obecnie s¹ zdeprawowani i nadu¿ywaj¹ swojej pozycji, by ograniczaæ u¿ywanie magii. Lepiej z nimi nie zadzieraj.~
@179 = ~Dziêki za ostrze¿enie. Bêdê uwa¿aæ, ale nie mogê przerwaæ poszukiwañ. Muszê siê dowiedzieæ, gdzie przetrzymuj¹ Imoen.~ 
@180 = ~To ja jestem niebezpieczny, nie oni. Poka¿ mi teraz, co masz na sprzeda¿.~ ~To ja jestem niebezpieczna, nie oni. Poka¿ mi teraz, co masz na sprzeda¿.~
